# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# local dev logs
.next-dev.log

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# UAT agent — auth sessions (contain Supabase tokens) and generated results
tests/uat/.auth/
tests/uat/results/
playwright-report/
test-results/

# local runtime artifacts
dev-server.log
tmp-*.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
supabase/.temp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
